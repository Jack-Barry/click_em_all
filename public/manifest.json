{
  "manifest_version": 3,
  "name": "Click 'em All",
  "description": "Clicks all buttons on a page based on provided selectors",
  "version": "0.0.1",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [],
  "permissions": ["scripting", "tabs"],
  "action": {
    "default_popup": "index.html"
  },
  "options_ui": {
    "page": "options.html"
  }
}
