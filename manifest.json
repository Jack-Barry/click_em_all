{
  "manifest_version": 3,
  "name": "Click 'em All",
  "description": "Clicks all buttons on a page based on provided selectors",
  "version": "0.0.1",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "scripts": ["src/scripts/background/index.ts"]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["src/scripts/content/index.ts"]
    }
  ],
  "action": {
    "default_popup": "pages/popup.html"
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  }
}
